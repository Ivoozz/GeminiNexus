# GeminiNexus Security Configuration
# Rename this file to .env and fill in your details.

# --- SECURITY (IMPORTANT) ---
# Use 'python3 scripts/setup_password.py' to generate your hash.
PASSWORD_HASH=$2b$12$EXAMPLE_HASH_REPLACE_ME
# Generate a long random string for JWT signing
SECRET_KEY=een-super-geheim-token-voor-jwt-12345

# --- CHANNELS ---
# Telegram Bot
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# E-mail (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=GeminiNexus <your_email@gmail.com>

# --- NETWORK ---
# The app will run on 0.0.0.0:8000 for Cloudflare compatibility.
